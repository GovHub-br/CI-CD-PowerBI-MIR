		isNameInferred
		sourceColumn: [Dia da Semana]

		annotation SummarizationSetBy = Automatic

	partition dCalendario = calculated
		mode: import
		source =
				
				VAR DataMinima = DATEVALUE(MIN(f_emendas_partidos[emissao_mes]))
				VAR DataMaxima = DATEVALUE(MAX(f_emendas_partidos[emissao_mes]))
				VAR AnoMinimo = YEAR(DataMinima)
				VAR AnoMaximo = YEAR(DataMaxima)
				
				RETURN
				ADDCOLUMNS (
				    CALENDAR ( DATE ( AnoMinimo, 1, 1 ), DATE ( AnoMaximo, 12, 31 ) ),
				    "Ano", YEAR ( [Date] ),
				    "Nome do Mês", FORMAT ( [Date], "MMMM" ),
				    "Mês Inteiro", MONTH ( [Date] ),
				    "Ano Mês", FORMAT ( [Date], "YYYY-MM" ),
				    "Trimestre", "T" & FORMAT ( [Date], "Q" ),
				    "Dia da Semana", FORMAT ( [Date], "DDDD" )
				)

	annotation PBI_Id = 72cf96895df941fd9308e98cded2659e

